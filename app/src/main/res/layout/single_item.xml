<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_height="wrap_content">

<!--    below is a cardView-->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="10dp"
        android:layout_margin="10dp"
        app:cardElevation="20dp"
        app:cardCornerRadius="15dp">

<!--        below is another linearLayout that aligns content vertically inside the cardView-->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="8dp"
            android:background="#FFFDD0">

<TextView
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:id="@+id/product_name"
    android:text="Product Name"
    android:textSize="22sp"
    android:textStyle="bold"
    android:textAlignment="center"
    android:textColor="#FFD700"
    android:fontFamily="serif"/>

<!--            below is our product_image-->
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:id="@+id/product_photo"
                android:src="@mipmap/ic_launcher"
                android:scaleType="centerCrop"
                android:layout_marginTop="3dp"/>

<!--            below is a TextView for the product_cost-->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/product_cost"
                android:text="Kes 500"
                android:fontFamily="sans-serif"
                android:layout_marginTop="5dp"
                android:textStyle="bold"
                android:textSize="25sp"
                android:textColor="#C9A227"
                android:layout_marginLeft="10dp"/>

<!--            below is a TextView for the product_description-->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/product_description"
                android:text="The product description will appear here"
                android:textSize="18sp"
                android:textColor="#7A6A58"
                android:layout_marginLeft="10dp"
                android:layout_marginTop="3dp"/>

<!--            below is the purchase now button-->
            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/btnPurchase"
                android:text="🛒Purchase now"
                android:textSize="20sp"
                android:padding="10dp"
                android:layout_marginTop="10dp"
                android:textColor="#FFFFFF"
                android:layout_marginLeft="50dp"
                android:layout_marginRight="50dp"
                android:fontFamily="serif"
                android:backgroundTint="#C9A227"/>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>