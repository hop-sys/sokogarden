<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#456"
    android:orientation="vertical"
    tools:context=".Signup">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="✨ Sign up"
        android:textSize="38sp"
        android:textAlignment="center"
        android:textStyle="italic|bold"
        android:textColor="#D3D8DC"
        android:background="@drawable/shape"
        android:padding="12dp"/>

<!--    below is a cardView-->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="30dp"
        app:cardElevation="10dp"
        android:layout_margin="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="12dp"
            android:background="#A7D0E2">

<!--            below is the editText for username-->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="👤 Enter username"
                android:textColorHint="#000"
                android:textSize="22sp"
                android:textColor="#000"
                android:background="#79B1CA"
                android:id="@+id/username"
                android:layout_margin="8dp"
                android:padding="10dp"/>

<!--             below is the editText for email-->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="📧 Enter your email"
                android:textColorHint="#000"
                android:textSize="22sp"
                android:textColor="#000"
                android:background="#79B1CA"
                android:id="@+id/email"
                android:layout_margin="8dp"
                android:padding="10dp"
                android:inputType="textEmailAddress"/>

<!--            below is the editText for password-->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="🔑 Enter your password"
                android:textColorHint="#000"
                android:textSize="22sp"
                android:textColor="#000"
                android:background="#79B1CA"
                android:id="@+id/password"
                android:layout_margin="8dp"
                android:padding="10dp"
                android:inputType="textPassword"/>

<!--            below is tthe editText for phone number-->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="📞 Enter your phone number"
                android:textColorHint="#000"
                android:textSize="22sp"
                android:textColor="#000"
                android:background="#79B1CA"
                android:id="@+id/phone"
                android:layout_margin="8dp"
                android:padding="10dp"
                android:inputType="number"/>

<!--            below is a signup button-->
            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="👤Sign up"
                android:textSize="25sp"
                android:padding="10dp"
                android:layout_marginLeft="40dp"
                android:layout_marginTop="25dp"
                android:layout_marginRight="40dp"
                android:textColor="#000"
                android:backgroundTint="#487DB1"
                android:id="@+id/signupBtn"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/signin_text"
                android:textSize="15sp"
                android:textAlignment="center"
                android:layout_marginTop="25dp"
                android:textColor="#000"
                android:id="@+id/signintxt"/>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>